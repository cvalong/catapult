---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? '/app'
---

<section class="mx-auto max-w-5xl px-6 py-24 text-center">
  <h1 class="text-5xl font-bold tracking-tight text-zinc-900 sm:text-6xl">
    The fastest way to<br />
    <span class="text-zinc-400">launch your next idea</span>
  </h1>
  <p class="mx-auto mt-6 max-w-xl text-lg text-zinc-500">
    __APP_NAME__ gives you everything you need to go from zero to paying customers.
    Stop rebuilding the same foundation. Start shipping.
  </p>
  <div class="mt-10 flex items-center justify-center gap-4">
    <a
      href={`${APP_URL}/sign-up`}
      class="rounded-lg bg-zinc-900 px-6 py-3 text-sm font-semibold text-white hover:bg-zinc-700 transition-colors"
    >
      Get started free
    </a>
    <a
      href="#features"
      class="rounded-lg border border-zinc-200 px-6 py-3 text-sm font-semibold text-zinc-700 hover:bg-zinc-50 transition-colors"
    >
      See how it works
    </a>
  </div>
</section>
