---
const features = [
  {
    title: 'Feature one',
    description: 'Describe the first core thing your product does and why it matters to your users.',
  },
  {
    title: 'Feature two',
    description: 'Describe the second core thing your product does and why it matters to your users.',
  },
  {
    title: 'Feature three',
    description: 'Describe the third core thing your product does and why it matters to your users.',
  },
]
---

<section id="features" class="border-t border-zinc-100 bg-zinc-50 py-24">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="text-center text-3xl font-bold tracking-tight text-zinc-900">
      Everything you need
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-zinc-500">
      Replace this with your product's value proposition.
    </p>
    <div class="mt-16 grid gap-8 sm:grid-cols-3">
      {features.map((feature) => (
        <div class="rounded-xl border border-zinc-200 bg-white p-6">
          <div class="mb-4 size-10 rounded-lg bg-zinc-900" />
          <h3 class="font-semibold text-zinc-900">{feature.title}</h3>
          <p class="mt-2 text-sm text-zinc-500">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
