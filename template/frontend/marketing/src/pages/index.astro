---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import Features from '../components/Features.astro'
import Pricing from '../components/Pricing.astro'
---

<Layout title="__APP_NAME__ — The fastest way to launch your next idea">
  <Nav />
  <main>
    <Hero />
    <Features />
    <Pricing />
  </main>
  <footer class="border-t border-zinc-100 py-8">
    <div class="mx-auto max-w-5xl px-6 text-center text-sm text-zinc-400">
      &copy; {new Date().getFullYear()} __APP_NAME__. All rights reserved.
    </div>
  </footer>
</Layout>
