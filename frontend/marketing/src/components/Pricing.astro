---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? '/app'

const tiers = [
  {
    name: 'Free',
    price: '$0',
    description: 'Everything you need to get started.',
    features: ['Feature one', 'Feature two', 'Up to X things'],
    cta: 'Get started free',
    href: `${APP_URL}/sign-up`,
    highlighted: false,
  },
  {
    name: 'Pro',
    price: '$19',
    description: 'For teams that need more.',
    features: ['Everything in Free', 'Unlimited things', 'Priority support'],
    cta: 'Start free trial',
    href: `${APP_URL}/sign-up?plan=pro`,
    highlighted: true,
  },
]
---

<section id="pricing" class="py-24">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="text-center text-3xl font-bold tracking-tight text-zinc-900">
      Simple pricing
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-center text-zinc-500">
      No hidden fees. Cancel anytime.
    </p>
    <div class="mt-16 grid gap-8 sm:grid-cols-2 sm:max-w-2xl sm:mx-auto">
      {tiers.map((tier) => (
        <div
          class={`rounded-xl border p-8 ${
            tier.highlighted
              ? 'border-zinc-900 bg-zinc-900 text-white'
              : 'border-zinc-200 bg-white text-zinc-900'
          }`}
        >
          <div class="flex items-baseline justify-between">
            <span class="font-semibold">{tier.name}</span>
            <span class="text-3xl font-bold">{tier.price}</span>
          </div>
          <p class={`mt-2 text-sm ${tier.highlighted ? 'text-zinc-400' : 'text-zinc-500'}`}>
            {tier.description}
          </p>
          <ul class="mt-6 space-y-3">
            {tier.features.map((feature) => (
              <li class={`flex items-center gap-2 text-sm ${tier.highlighted ? 'text-zinc-300' : 'text-zinc-600'}`}>
                <svg class={`size-4 shrink-0 ${tier.highlighted ? 'text-zinc-400' : 'text-zinc-400'}`} viewBox="0 0 16 16" fill="currentColor">
                  <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0z"/>
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          <a
            href={tier.href}
            class={`mt-8 block rounded-lg px-4 py-2.5 text-center text-sm font-semibold transition-colors ${
              tier.highlighted
                ? 'bg-white text-zinc-900 hover:bg-zinc-100'
                : 'bg-zinc-900 text-white hover:bg-zinc-700'
            }`}
          >
            {tier.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
