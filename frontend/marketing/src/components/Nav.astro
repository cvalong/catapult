---
const APP_URL = import.meta.env.PUBLIC_APP_URL ?? '/app'
---

<header class="sticky top-0 z-50 border-b border-zinc-100 bg-white/80 backdrop-blur">
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="text-lg font-semibold tracking-tight">__APP_NAME__</a>
    <div class="flex items-center gap-6">
      <a href="#features" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">Features</a>
      <a href="#pricing" class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors">Pricing</a>
      <a
        href={`${APP_URL}/sign-in`}
        class="text-sm text-zinc-500 hover:text-zinc-900 transition-colors"
      >
        Sign in
      </a>
      <a
        href={`${APP_URL}/sign-up`}
        class="rounded-lg bg-zinc-900 px-4 py-2 text-sm font-medium text-white hover:bg-zinc-700 transition-colors"
      >
        Get started
      </a>
    </div>
  </nav>
</header>
